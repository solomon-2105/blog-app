<!DOCTYPE html>
<html>
<head>
  <title>My Blog</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="navbar">
  <div class="nav-left">My Blog</div>
  <div class="nav-right">
    <a href="/blogs">All Blogs</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
  </div>
</div>

<div class="container">
  <div class="main-card">

    <h1>Create a Blog</h1>

    <form action="/create" method="POST" class="form">
      <input type="text" name="title" placeholder="Post Title" required>
      <textarea name="content" placeholder="Write your content..." required></textarea>
      <button type="submit">Publish</button>
    </form>

    <hr style="margin:40px 0; border:1px solid rgba(255,255,255,0.2);">

    <h1>Recent Blogs</h1>

    <% if (recentPosts.length === 0) { %>
      <p id="sinai">No blogs yet.</p>
    <% } %>

    <% recentPosts.forEach(post => { %>
      <div class="post">
        <h2><%= post.title %></h2>
        <p><%= post.content %></p>
      </div>
    <% }) %>

  </div>
</div>

<footer>
  © 2026 Sinai. All rights reserved.
</footer>

</body>
</html>