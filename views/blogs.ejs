<!DOCTYPE html>
<html>
<head>
  <title>My Blogs</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="navbar">
  <div class="nav-left">My Blog</div>
  <div class="nav-right">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
  </div>
</div>

<div class="container">
  <h1>All Blogs</h1>

  <% posts.forEach(post => { %>
    <div class="post">
      <h2><%= post.title %></h2>
      <p><%= post.content %></p>

      <div class="actions">
        <a href="/edit/<%= post.id %>" class="edit-btn">Edit</a>

        <form action="/delete/<%= post.id %>" method="POST">
          <button class="delete-btn">Delete</button>
        </form>
      </div>
    </div>
  <% }) %>
</div>

<footer>
  © 2026 Your Name. All rights reserved.
</footer>

</body>
</html>